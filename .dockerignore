# Dependencies — installed fresh inside the image
node_modules
frontend/node_modules
backend/node_modules

# Git history
.git
.gitignore
.gitattributes

# Environment secrets — NEVER bake into the image
.env
backend/.env
frontend/.env
**/*.env.local
**/*.env.development
**/*.env.test

# Pre-built frontend (built inside Docker during Stage 1)
frontend/build

# Test artifacts
**/__tests__
**/coverage
**/*.test.js
**/*.spec.js

# Dev logs
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*

# Editor files
.vscode
.idea
**/*.swp
**/*.swo

# OS files
.DS_Store
Thumbs.db

# Backup files
**/*.backup
backend/backups
