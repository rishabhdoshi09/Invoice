# ─── DATABASE ────────────────────────────────────────────────────────────────
# PostgreSQL connection settings. Use a secrets manager in production.
DATABASE_NAME=customerInvoice
DB_USER=postgres
PASSWORD=CHANGE_ME_use_secrets_manager
DB_HOST=127.0.0.1
DB_PORT=5432

# ─── SERVER ───────────────────────────────────────────────────────────────────
PORT=8001

# ─── ENVIRONMENT ─────────────────────────────────────────────────────────────
# MUST be "production" in any non-development deployment.
NODE_ENV=production
IS_DEV=false

# ─── SECURITY ────────────────────────────────────────────────────────────────
# JWT_SECRET: MUST be a long, cryptographically random string unique per deployment.
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# NEVER reuse between environments. NEVER commit the real value.
JWT_SECRET=CHANGE_ME_generate_with_node_crypto_randomBytes_64_hex
JWT_EXPIRES_IN=2h

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. No trailing slashes.
CORS_ORIGINS=http://localhost:3000

# ─── NOTIFICATIONS ───────────────────────────────────────────────────────────
# Telegram bot token and chat ID for operational alerts.
# Rotate token at: https://t.me/BotFather
# Store in secrets manager — do NOT commit real values.
TELEGRAM_BOT_TOKEN=CHANGE_ME_rotate_at_BotFather
TELEGRAM_CHAT_ID=CHANGE_ME_your_chat_id

# ─── FINANCIAL GUARD ─────────────────────────────────────────────────────────
# Emergency bypass secret for the financial integrity guard (HALT state).
# Leave blank to DISABLE the bypass (safest in production).
# If set, store ONLY in secrets manager — never in this file.
FINANCIAL_GUARD_OVERRIDE_SECRET=
